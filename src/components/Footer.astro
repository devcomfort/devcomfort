---
import siteConfig from '../data/site-config';

const socialLinks = siteConfig.socialLinks || [];
const navLinks = siteConfig.footerNavLinks || [];
---

<footer class="max-w-5xl mx-auto px-6 py-10 border-t border-border-main flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <p class="font-sans text-sm text-text-tertiary">
        &copy; {new Date().getFullYear()}&nbsp;<a class="hover:text-accent hover:underline" href="/">{siteConfig.title}</a>. All rights reserved.
    </p>
    <div class="flex flex-wrap gap-6">
        {navLinks.map((link) => (
            <a class="font-sans text-sm text-text-secondary hover:text-accent hover:underline" href={link.href}>
                {link.text}
            </a>
        ))}
        {socialLinks.map((link) => (
            <a
                class="font-sans text-sm text-text-secondary hover:text-accent hover:underline inline-flex items-center gap-2"
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
            >
                {link.text}
            </a>
        ))}
    </div>
</footer>
