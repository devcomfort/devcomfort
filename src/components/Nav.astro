---
import NavLink from './NavLink.astro';
import ThemeToggle from './ThemeToggle.astro';
import siteConfig from '../data/site-config';

const navLinks = siteConfig.headerNavLinks || [];
---

<nav class="sticky top-0 z-50 h-14 bg-bg-elevated/90 backdrop-blur border-b border-border-main">
    <div class="max-w-5xl mx-auto px-6 h-full flex items-center justify-between">
        <a href="/" class="font-mono text-sm font-medium text-main tracking-tight hover:text-accent transition-colors">
            devcomfort
        </a>
        <ul class="hidden md:flex items-center gap-8">
            {navLinks.map((link) => (
                <li>
                    <a
                        href={link.href}
                        class="font-sans text-sm text-text-secondary hover:text-main transition-colors relative after:content-[''] after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-px after:bg-accent after:transition-[width] after:duration-200 hover:after:w-full"
                    >
                        {link.text}
                    </a>
                </li>
            ))}
        </ul>
        <div class="flex items-center gap-2">
            <ThemeToggle />
            <!-- Mobile menu button -->
            <button
                class="menu-toggle md:hidden w-8 h-8 flex items-center justify-center"
                aria-label="Open Menu"
                aria-expanded="false"
                aria-controls="menu-items"
            >
                <span class="w-5 h-px bg-current" />
            </button>
        </div>
    </div>
    <!-- Mobile menu -->
    <ul id="menu-items" class="menu hidden md:hidden flex-col gap-1 px-6 pb-4 bg-bg-elevated border-b border-border-main">
        {navLinks.map((link) => (
            <li>
                <a
                    href={link.href}
                    class="font-sans text-sm text-text-secondary hover:text-main py-2 block"
                >
                    {link.text}
                </a>
            </li>
        ))}
    </ul>
</nav>

<script>
    function menuToggle() {
        const menu = document.querySelector('.menu');
        const btn = document.querySelector('.menu-toggle');
        btn?.addEventListener('click', () => {
            const expanded = btn.getAttribute('aria-expanded') === 'true';
            btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
            menu?.classList.toggle('hidden');
            menu?.classList.toggle('flex');
        });
    }
    menuToggle();
    document.addEventListener('astro:after-swap', menuToggle);
</script>
