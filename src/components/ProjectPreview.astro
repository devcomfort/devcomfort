---
import { type CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import { slugify } from '../utils/common-utils';

export type Props = {
    project: CollectionEntry<'projects'>;
    class?: string;
    headingLevel?: 'h2' | 'h3';
};

const { project, class: className, headingLevel = 'h2' } = Astro.props;
const { title, publishDate, description, tags = [], projectUrl, sourceUrl } = project.data;
const TitleTag = headingLevel;
---

<article class:list={[className]}>
    <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1 mb-2">
        <TitleTag class="text-xl font-serif font-medium leading-tight">
            <a class="hover:underline hover:underline-offset-2" href={`/projects/${project.slug}/`}>{title}</a>
        </TitleTag>
        <span class="text-sm">
            <FormattedDate date={publishDate} />
        </span>
    </div>
    {description && <p class="text-sm leading-relaxed mb-2">{description}</p>}
    <div class="flex flex-wrap gap-4 text-sm">
        {projectUrl && <a class="hover:underline hover:underline-offset-2" href={projectUrl} target="_blank" rel="noopener noreferrer">Live Demo ↗</a>}
        {sourceUrl && <a class="hover:underline hover:underline-offset-2" href={sourceUrl} target="_blank" rel="noopener noreferrer">Source ↗</a>}
    </div>
    {
        tags.length > 0 && (
            <div class="mt-2 flex flex-wrap gap-2">
                {tags.map((tag) => (
                    <a class="text-xs border border-current py-0.5 px-2 hover:bg-muted" href={`/tags/${slugify(tag)}/`}>
                        {tag}
                    </a>
                ))}
            </div>
        )
    }
</article>
