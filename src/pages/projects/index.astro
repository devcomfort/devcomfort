---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectPreview from '../../components/ProjectPreview.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';

const allProjects = (await getCollection('projects')).sort(sortItemsByDateDesc);
---

<BaseLayout title="Projects" description="오픈소스 라이브러리, 포트폴리오 프로젝트">
    <div class="max-w-[720px]">
        <h1 class="font-sans text-xs font-semibold tracking-[0.1em] uppercase text-text-tertiary mb-6 pb-3 border-b border-border-main flex items-center gap-3 before:font-mono before:text-xs before:text-accent before:content-['01']">
            Projects
        </h1>
        {allProjects.length > 0 ? (
            <div class="flex flex-col">
                {allProjects.map((project) => <ProjectPreview project={project} class="mb-0" />)}
            </div>
        ) : (
            <p class="font-serif text-text-secondary">아직 프로젝트가 없습니다.</p>
        )}
    </div>
</BaseLayout>
