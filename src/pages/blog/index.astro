---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostPreview from '../../components/PostPreview.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';

const allPosts = (await getCollection('blog')).sort(sortItemsByDateDesc);
---

<BaseLayout title="Blog" description="기술 블로그 — 개발 경험, AI 연구, 오픈소스 프로젝트">
    <div class="max-w-[720px]">
        <h1 class="font-sans text-xs font-semibold tracking-[0.1em] uppercase text-text-tertiary mb-6 pb-3 border-b border-border-main flex items-center gap-3 before:font-mono before:text-xs before:text-accent before:content-['01']">
            Blog
        </h1>
        {allPosts.length > 0 ? (
            <div class="flex flex-col">
                {allPosts.map((post) => <PostPreview post={post} class="mb-0" />)}
            </div>
        ) : (
            <p class="font-serif text-text-secondary">아직 게시물이 없습니다.</p>
        )}
    </div>
</BaseLayout>
