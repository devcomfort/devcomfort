---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { slugify } from '../../utils/common-utils';

export async function getStaticPaths() {
    const posts = await getCollection('blog');
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post }
    }));
}

type Props = {
    post: CollectionEntry<'blog'>;
};

const { post } = Astro.props;
const { title, publishDate, updatedDate, excerpt, tags = [], seo } = post.data;
const { Content } = await render(post);
---

<BaseLayout title={seo?.title ?? title} description={seo?.description ?? excerpt ?? ''} image={seo?.image} pageType="article">
    <article class="mb-16 sm:mb-24">
        <header class="mb-8">
            <h1 class="text-3xl font-serif font-medium leading-tight sm:text-4xl sm:leading-tight">{title}</h1>
            <div class="mt-4 text-sm">
                <FormattedDate date={publishDate} />
                {updatedDate && (
                    <span> (updated: <FormattedDate date={updatedDate} />)</span>
                )}
            </div>
            {
                tags.length > 0 && (
                    <div class="mt-4 flex flex-wrap gap-2">
                        {tags.map((tag) => (
                            <a class="text-xs border border-current py-0.5 px-2 hover:bg-muted" href={`/tags/${slugify(tag)}/`}>
                                {tag}
                            </a>
                        ))}
                    </div>
                )
            }
        </header>
        <div class="prose prose-dante max-w-none sm:prose-lg">
            <Content />
        </div>
    </article>
</BaseLayout>
