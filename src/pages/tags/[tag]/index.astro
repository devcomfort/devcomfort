---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostPreview from '../../../components/PostPreview.astro';
import ProjectPreview from '../../../components/ProjectPreview.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import { getAllTags, getPostsByTag, sortItemsByDateDesc } from '../../../utils/data-utils';
import { slugify } from '../../../utils/common-utils';

export async function getStaticPaths() {
    const [posts, projects, research] = await Promise.all([
        getCollection('blog'),
        getCollection('projects'),
        getCollection('research'),
    ]);
    const allItems = [...posts, ...projects, ...research];
    const tags = getAllTags(allItems);
    return tags.map((tag) => ({
        params: { tag: tag.slug },
        props: { tag }
    }));
}

const { tag } = Astro.props;
const [allPosts, allProjects, allResearch] = await Promise.all([
    getCollection('blog'),
    getCollection('projects'),
    getCollection('research'),
]);

const tagPosts = getPostsByTag(allPosts, tag.slug).sort(sortItemsByDateDesc);
const tagProjects = getPostsByTag(allProjects, tag.slug).sort(sortItemsByDateDesc);
const tagResearch = getPostsByTag(allResearch, tag.slug).sort(sortItemsByDateDesc);
---

<BaseLayout title={`Tag: ${tag.name}`} description={`${tag.name} 태그의 콘텐츠 목록`}>
    <div class="mb-16 sm:mb-24">
        <h1 class="mb-12 text-2xl font-serif italic sm:mb-16 sm:text-3xl">#{tag.name}</h1>

        {tagPosts.length > 0 && (
            <section class="mb-12">
                <h2 class="mb-6 text-lg font-serif font-semibold">블로그</h2>
                {tagPosts.map((post) => <PostPreview post={post} class="mb-10 sm:mb-12" />)}
            </section>
        )}

        {tagProjects.length > 0 && (
            <section class="mb-12">
                <h2 class="mb-6 text-lg font-serif font-semibold">프로젝트</h2>
                {tagProjects.map((project) => <ProjectPreview project={project} class="mb-10 sm:mb-12" />)}
            </section>
        )}

        {tagResearch.length > 0 && (
            <section class="mb-12">
                <h2 class="mb-6 text-lg font-serif font-semibold">연구</h2>
                {tagResearch.map((item) => (
                    <article class="py-6 border-b border-border-main last:border-b-0 mb-10 sm:mb-12">
                        <time class="font-mono text-xs text-text-tertiary mb-2 block">
                            <FormattedDate date={item.data.publishDate} />
                        </time>
                        <h3 class="font-serif text-lg font-semibold leading-tight mb-2">
                            <a class="text-main hover:text-accent hover:underline hover:decoration-1 hover:underline-offset-2" href={`/research/${item.id}/`}>{item.data.title}</a>
                        </h3>
                        {item.data.description && <p class="font-serif text-base leading-relaxed text-text-secondary mb-2">{item.data.description}</p>}
                        {item.data.tags && item.data.tags.length > 0 && (
                            <div class="mt-3 flex flex-wrap gap-2">
                                {item.data.tags.map((t) => (
                                    <a class="font-mono text-xs text-text-secondary bg-bg-muted border border-border-main px-3 py-0.5 rounded-sm hover:bg-accent/8 hover:border-accent hover:text-accent no-underline transition-colors" href={`/tags/${slugify(t)}/`}>
                                        {t}
                                    </a>
                                ))}
                            </div>
                        )}
                    </article>
                ))}
            </section>
        )}
    </div>
</BaseLayout>
