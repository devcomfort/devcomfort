---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { slugify } from '../../utils/common-utils';

export async function getStaticPaths() {
    const research = await getCollection('research');
    return research.map((item) => ({
        params: { slug: item.slug },
        props: { item }
    }));
}

type Props = {
    item: CollectionEntry<'research'>;
};

const { item } = Astro.props;
const { title, publishDate, description, tags = [], paperUrl, seo } = item.data;
const { Content } = await item.render();
---

<BaseLayout title={seo?.title ?? title} description={seo?.description ?? description ?? ''} image={seo?.image}>
    <article class="mb-16 sm:mb-24">
        <header class="mb-8">
            <h1 class="text-3xl font-serif font-medium leading-tight sm:text-4xl sm:leading-tight">{title}</h1>
            <div class="mt-4 text-sm">
                <FormattedDate date={publishDate} />
            </div>
            {paperUrl && (
                <div class="mt-4">
                    <a class="text-sm hover:underline hover:underline-offset-2" href={paperUrl} target="_blank" rel="noopener noreferrer">
                        Read Paper ↗
                    </a>
                </div>
            )}
            {
                tags.length > 0 && (
                    <div class="mt-4 flex flex-wrap gap-2">
                        {tags.map((tag) => (
                            <a class="text-xs border border-current py-0.5 px-2 hover:bg-muted" href={`/tags/${slugify(tag)}/`}>
                                {tag}
                            </a>
                        ))}
                    </div>
                )
            }
        </header>
        <div class="prose prose-dante max-w-none sm:prose-lg">
            <Content />
        </div>
    </article>
</BaseLayout>
