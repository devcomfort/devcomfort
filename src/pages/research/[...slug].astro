---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import PaperBadge from '../../components/PaperBadge.astro';
import { slugify } from '../../utils/common-utils';

export async function getStaticPaths() {
    const research = await getCollection('research');
    return research.map((item) => ({
        params: { slug: item.slug },
        props: { item }
    }));
}

type Props = {
    item: CollectionEntry<'research'>;
};

const { item } = Astro.props;
const { title, publishDate, description, tags = [], paperUrl, seo } = item.data;
const { Content } = await item.render();
---

<BaseLayout title={seo?.title ?? title} description={seo?.description ?? description ?? ''} image={seo?.image}>
    <article class="max-w-[720px]">
        <header class="mb-8">
            <h1 class="font-serif text-3xl font-semibold leading-tight text-main sm:text-[1.875rem] sm:leading-tight">{title}</h1>
            <time class="font-mono text-xs text-text-tertiary mt-4 block">
                <FormattedDate date={publishDate} />
            </time>
            {paperUrl && (
                <div class="mt-4">
                    <PaperBadge url={paperUrl} />
                </div>
            )}
            {
                tags.length > 0 && (
                    <div class="mt-4 flex flex-wrap gap-2">
                        {tags.map((tag) => (
                            <a class="font-mono text-xs text-text-secondary bg-bg-muted border border-border-main px-3 py-0.5 rounded-sm hover:bg-accent/8 hover:border-accent hover:text-accent no-underline transition-colors" href={`/tags/${slugify(tag)}/`}>
                                {tag}
                            </a>
                        ))}
                    </div>
                )
            }
        </header>
        <div class="prose prose-dante max-w-none sm:prose-lg">
            <Content />
        </div>
    </article>
</BaseLayout>
